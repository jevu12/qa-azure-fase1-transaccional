{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExecutionOutcome",
  "description": "Resultado de la ejecución de un Test Case individual",
  "type": "object",
  "required": [
    "test_case_id",
    "us_id",
    "result",
    "executed_at",
    "tc_evidence_dir",
    "manifest_file",
    "steps_executed",
    "steps_with_uploaded_verified_evidence",
    "steps_results",
    "evidence"
  ],
  "properties": {
    "test_point_id": {
      "type": ["integer", "null"],
      "description": "ID del Test Point resuelto para publicar resultado en run planificado"
    },
    "test_case_id": {
      "type": "integer",
      "description": "ID del Test Case en Azure DevOps"
    },
    "test_case_revision": {
      "type": ["integer", "null"],
      "description": "Revisión del Test Case al momento de publicar resultado"
    },
    "test_case_title": {
      "type": ["string", "null"],
      "description": "Título del Test Case al momento de publicar resultado"
    },
    "us_id": {
      "type": "integer",
      "description": "ID de la User Story asociada"
    },
    "us_evidence_dir": {
      "type": ["string", "null"],
      "description": "Carpeta contenedora por US: outputs/evidencias/<sprint>/US-<us_id>/"
    },
    "tc_evidence_dir": {
      "type": "string",
      "description": "Carpeta obligatoria por TC: outputs/evidencias/<sprint>/US-<us_id>/TC-<tc_id>/"
    },
    "manifest_file": {
      "type": "string",
      "description": "Ruta al manifest transaccional del TC"
    },
    "steps_executed": {
      "type": "integer",
      "minimum": 0
    },
    "steps_with_uploaded_verified_evidence": {
      "type": "integer",
      "minimum": 0
    },
    "missing_evidence_steps": {
      "type": "array",
      "items": { "type": "integer" }
    },
    "evidence_coverage_percent": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100
    },
    "suite_id": {
      "type": "integer",
      "description": "ID de la Test Suite"
    },
    "run_id": {
      "type": ["integer", "null"],
      "description": "ID del Test Run si existe"
    },
    "scenario_id": {
      "type": "string",
      "description": "ID del escenario (ESC-HP-01, ESC-NEG-02, etc.)"
    },
    "result": {
      "type": "string",
      "enum": ["PASS", "FAIL", "BLOCKED", "NOT_EXECUTED"],
      "description": "Resultado de la ejecución"
    },
    "outcome": {
      "type": ["string", "null"],
      "enum": ["Passed", "Failed", "Blocked", "NotApplicable", null],
      "description": "Outcome compatible con publicación de resultados en Azure DevOps Test Runs"
    },
    "steps_results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "step_number": { "type": "integer" },
          "action": { "type": "string" },
          "expected": { "type": "string" },
          "actual": { "type": "string" },
          "result": { "type": "string", "enum": ["PASS", "FAIL", "BLOCKED"] },
          "evidence_file": { "type": ["string", "null"] },
          "upload_status": {
            "type": ["string", "null"],
            "enum": ["PENDING", "UPLOADED_VERIFIED", "FAILED", null]
          },
          "attachment_id": { "type": ["string", "null"] }
        }
      }
    },
    "failure_details": {
      "type": ["object", "null"],
      "properties": {
        "step_failed": { "type": "integer" },
        "expected_behavior": { "type": "string" },
        "actual_behavior": { "type": "string" },
        "classification": {
          "type": "string",
          "enum": [
            "bug_funcional",
            "bug_visual",
            "bug_performance",
            "flaky_test",
            "environment_problem",
            "data_problem",
            "automation_error",
            "blocked_by_dependency"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Nivel de confianza en la clasificación (0-1)"
        },
        "recommendation": {
          "type": "string",
          "enum": ["create_bug", "register_impediment", "document_finding", "retry", "skip"]
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "filename": { "type": "string" },
          "type": { "type": "string", "enum": ["screenshot", "video", "log", "trace"] },
          "step": { "type": ["integer", "null"] },
          "path": { "type": "string" },
          "upload_status": {
            "type": ["string", "null"],
            "enum": ["PENDING", "UPLOADED_VERIFIED", "FAILED", null]
          },
          "attachment_id": { "type": ["string", "null"] }
        }
      }
    },
    "duration_seconds": {
      "type": "number",
      "description": "Duración de la ejecución en segundos"
    },
    "executed_at": {
      "type": "string",
      "format": "date-time"
    },
    "executed_by": {
      "type": "string",
      "description": "Agente o usuario que ejecutó. Si qa_assignee.source es 'mcp_authenticated_user', corresponde al usuario logueado en el MCP de Azure DevOps."
    },
    "platform": {
      "type": "string",
      "description": "Plataforma donde se ejecutó: web, android, ios, api"
    },
    "environment": {
      "type": "string",
      "description": "Ambiente de ejecución: QA, staging, production"
    },
    "comments": {
      "type": ["string", "null"],
      "description": "Comentarios adicionales de la ejecución"
    }
  }
}
